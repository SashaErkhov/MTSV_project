%выравнивание слова СОДЕРЖАНИЕ (Arial/Helvetica, 16pt, Bold)
\AtBeginDocument{%
	\renewcommand{\contentsname}{\hfill\fontsize{16pt}{16pt}\sffamily\bfseries СОДЕРЖАНИЕ \hfill}%
}
\AtBeginDocument{\renewcommand{\cftaftertoctitle}{\hfill}}

%жирность оглавления
\renewcommand{\cftsecfont}{\normalfont}
\renewcommand{\cftsecpagefont}{\normalfont}

%specialsection (Arial/Helvetica, 16pt, Bold)
\newcommand{\specialsection}[1]{
	\phantomsection
	\begin{center}
		\fontsize{16pt}{16pt}\sffamily\bfseries #1
	\end{center}
	\par
	\normalsize
	\addcontentsline{toc}{section}{#1}}

%section (Arial/Helvetica, 16pt, Bold)
\titleformat{\section}
{\fontsize{16pt}{16pt}\sffamily\bfseries}
{\thesection}
{1em}
{\centering}

%subsection (Arial/Helvetica, 14pt, Bold)
\titleformat{\subsection}
{\fontsize{14pt}{14pt}\sffamily\bfseries}
{\thesubsection}
{1em}
{\centering}

%точки в содержании
\renewcommand{\cftsecleader}{\cftdotfill{\cftdotsep}}

